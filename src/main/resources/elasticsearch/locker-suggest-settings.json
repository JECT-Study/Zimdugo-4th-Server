{
  "analysis": {
    "char_filter": {
      "whitespace_remove_filter": {
        "type": "pattern_replace",
        "pattern": "\\s+",
        "replacement": ""
      }
    },
    "tokenizer": {
      "standard_tokenizer": {
        "type": "standard"
      }
    },
    "filter": {
      "autocomplete_filter": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 20
      }
    },
    "analyzer": {
      "autocomplete_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "char_filter": [
          "whitespace_remove_filter"
        ],
        "filter": [
          "lowercase",
          "autocomplete_filter"
        ]
      },
      "suggest_search_analyzer": {
        "type": "custom",
        "tokenizer": "standard",
        "char_filter": [
          "whitespace_remove_filter"
        ],
        "filter": [
          "lowercase"
        ]
      }
    }
  }
}
