# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
tab_width = 4
trim_trailing_whitespace = true
insert_final_newline = true

[*.java]
max_line_length = 120

[*.{yml,yaml}]
indent_size = 2

[*.{json,xml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.properties]
charset = utf-8

[{gradlew,*.bat}]
end_of_line = crlf

[gradlew]
end_of_line = lf